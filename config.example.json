    "konban_script": "",
    "brain_script": "",
    "recall_script": ""
  },
  "daemon_label": "org.knowledge-base.extract",
  "briefing": {
    "key_entities": ["My Project"],
    "key_attrs": ["status", "version", "users"],
    "domain_order": ["MyProject", "Personal", "Infrastructure", "Other"]
  }
}
