    {"name": "Personal", "patterns": ["personal-support", "personal/support"]},
    {"name": "Infrastructure", "patterns": ["knowledge-base", "claude-sessions"]}
  ],
  "git_repos": [
    "~/github/my-project"
  ],
  "owner_entity_names": ["Jane Doe", "jdoe", "J. Doe"],
